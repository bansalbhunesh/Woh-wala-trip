# =============================================================================
# Yaarlore Environment Variables — Copy to .env.local for local development
# ALL variables marked REQUIRED must be set before deploying to production.
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co          # REQUIRED
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here                   # REQUIRED
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here               # REQUIRED — never expose to browser

# ── Auth ─────────────────────────────────────────────────────────────────────
OTP_HMAC_SECRET=generate_with_openssl_rand_hex_32                  # REQUIRED — used to hash OTP codes
NEXT_PUBLIC_SITE_URL=https://yourdomain.com                        # REQUIRED — OAuth redirect base

# ── AI Worker ─────────────────────────────────────────────────────────────────
AI_WORKER_URL=https://your-worker.onrender.com                     # REQUIRED — no localhost allowed in prod
AI_WORKER_SECRET=generate_with_openssl_rand_hex_32                 # REQUIRED — bearer token for worker auth
AI_WORKER_HMAC_SECRET=generate_with_openssl_rand_hex_32            # REQUIRED — HMAC signing key (must match Render)

# ── Payments ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your_key_id                   # REQUIRED — safe to expose (public)
RAZORPAY_KEY_SECRET=your_razorpay_secret                           # REQUIRED — server-only
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret                        # REQUIRED — set in Razorpay dashboard

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key                              # REQUIRED — OTPs print to console if absent
RESEND_FROM_EMAIL=hello@yourdomain.com                             # REQUIRED — must be verified domain in Resend

# ── Rate Limiting ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io               # REQUIRED in production — rate limiting
UPSTASH_REDIS_REST_TOKEN=your_upstash_token                        # REQUIRED in production

# ── Cron Security ─────────────────────────────────────────────────────────────
CRON_SECRET=generate_with_openssl_rand_hex_32                       # REQUIRED — all 7 cron routes check this

# ── Observability ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key                       # Recommended — product analytics
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com                   # Recommended
LANGFUSE_PUBLIC_KEY=pk-lf-your_key                                 # Recommended — AI observability
LANGFUSE_SECRET_KEY=sk-lf-your_key                                 # Recommended
LANGFUSE_HOST=https://cloud.langfuse.com                           # Recommended
NEXT_PUBLIC_SENTRY_DSN=https://your@sentry.io/project              # Recommended — error tracking

# ── Cost Controls ─────────────────────────────────────────────────────────────
MONTHLY_TOKEN_CAP_PER_USER=500000                                   # Optional — default 500k tokens/user/month

# ── Demo / YC Seeder ─────────────────────────────────────────────────────────
DEMO_SEED_SECRET=generate_with_openssl_rand_hex_32                  # REQUIRED to call /api/admin/seed-demo

# ── Web Push Notifications ────────────────────────────────────────────────────
# Generate keys: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k))"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BMG7ygIMwWzipB2AFDsytHEgm_NFoRAB3tEyyQPPY75dGU-eCPjvP2up2a5oVUAcbUY-OCT8S8JjWpliKHy-_II
VAPID_PRIVATE_KEY=your_vapid_private_key_here                       # REQUIRED server-only — never expose
VAPID_CONTACT_EMAIL=mailto:hello@yaarlore.app

# ── Email Validation (optional spam prevention) ────────────────────────────────
ABSTRACT_API_KEY=your_abstract_api_key                             # Optional — disposable email detection
KICKBOX_API_KEY=your_kickbox_api_key                               # Optional — email deliverability check

# =============================================================================
# AI Worker environment (set on Render, not Vercel)
# Copy these to your Render service environment
# =============================================================================

# ANTHROPIC_API_KEY=sk-ant-your_key                                 # REQUIRED on Render
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co                     # REQUIRED on Render
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here              # REQUIRED on Render
# AI_WORKER_SECRET=same_as_above                                    # REQUIRED on Render
# AI_WORKER_HMAC_SECRET=same_as_above                               # REQUIRED on Render

# Optional on Render:
# FAL_API_KEY=your_fal_api_key                                      # fal.ai image generation
# VOYAGE_API_KEY=your_voyage_api_key                                # Voyage AI photo embeddings
# REDIS_URL=https://your-redis.upstash.io                           # Cross-instance cooldown
# REDIS_TOKEN=your_upstash_token                                    # Cross-instance cooldown
# LORE_EVAL_SAMPLE_RATE=1.0                                         # 1.0 = evaluate all (recommended)
# DEBUG_ENABLED=false                                               # Never set to true in prod
