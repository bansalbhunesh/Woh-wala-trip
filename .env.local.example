# Woh Wala Trip — Environment Configuration

# Supabase (Auth & Database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Worker (Lore Generation)
AI_WORKER_URL=http://localhost:8000
AI_WORKER_SECRET=your-ai-worker-secret

# AI Worker HMAC signing (Phase 1 Security Foundation — SEC-08)
# Generate a strong random secret: openssl rand -hex 32
# Must be set on BOTH Vercel (Next.js) and Render (AI worker) simultaneously during rollout.
AI_WORKER_HMAC_SECRET=

# Razorpay (Payments)
# Test keys start with rzp_test_  —  live keys start with rzp_live_
# NEXT_PUBLIC_RAZORPAY_KEY_ID is sent to the browser (safe — it's the public identifier)
# RAZORPAY_KEY_SECRET must NEVER be in client-side code
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
# Webhook secret — from Razorpay Dashboard → Webhooks → your webhook → Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Vercel (Optional, for production origin)
VERCEL_URL=your-app-url.vercel.app

# Cron security — Vercel sends this as Bearer token to /api/cron/* routes.
# Generate with: openssl rand -hex 32
# Must be set in Vercel Dashboard → Project Settings → Environment Variables.
CRON_SECRET=your-cron-secret

# Email (OTP delivery + anniversary emails)
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yaarlore.app

# OTP HMAC signing secret — REQUIRED in production. Hard fail if not set.
# Generate with: openssl rand -hex 32
# NEVER use a fallback or hardcoded value — will throw on startup if missing.
OTP_HMAC_SECRET=your-otp-hmac-secret

# Anti-spam: third-party email validators (all optional — local blocklist runs without keys)
ABSTRACT_API_KEY=your-abstract-api-key
KICKBOX_API_KEY=your-kickbox-api-key
# Disify requires no key (free, keyless API)

# Admin API (for GET /api/admin/security-log)
# Generate with: openssl rand -hex 32
ADMIN_API_TOKEN=your-admin-token

# Observability — Langfuse (optional; all trace calls are no-ops without keys)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# Sentry — Error tracking (production only; leave empty in development)
# Get your DSN from: https://sentry.io → Your Project → Settings → SDK Setup
NEXT_PUBLIC_SENTRY_DSN=
