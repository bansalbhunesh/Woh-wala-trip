{
  "name": "yaarlore",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:visual": "playwright test tests/e2e/visual-regression.spec.ts",
    "test:e2e:update-snapshots": "playwright test tests/e2e/visual-regression.spec.ts --update-snapshots",
    "test:ai:deterministic": "cd ai-worker && python -X utf8 -m tests.run_deterministic",
    "test:ai:eval": "cd ai-worker && python -m pytest tests/ -v --tb=short -k 'not llm'",
    "test:ai:promptfoo": "npx promptfoo eval --config tests/ai/promptfoo.yaml",
    "test": "npm run type-check && npm run lint && npm run test:unit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build --output-dir storybook-static",
    "chromatic": "npx chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --storybook-build-dir=storybook-static",
    "prepare": "node scripts/prepare.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.50.0",
    "@trpc/client": "^11.0.0-rc.446",
    "@trpc/next": "^11.0.0-rc.446",
    "@trpc/react-query": "^11.0.0-rc.446",
    "@trpc/server": "^11.0.0-rc.446",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "pino": "^10.3.1",
    "posthog-js": "^1.373.5",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.3",
    "superjson": "^2.2.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/nextjs": "^10.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^7.2.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "ajv": "^8.20.0",
    "ajv-keywords": "^5.1.0",
    "autoprefixer": "^10.4.20",
    "chromatic": "^16.10.1",
    "eslint": "^9.15.0",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "msw": "^2.14.6",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "storybook": "^10.4.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.15",
    "three": "^0.184.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  }
}
